{
  "expo": {
    "name": "GEMSTONE CODE",
    "slug": "gemstone-code",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_logo_final.png",
    "scheme": "gemstonecode",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E1510",
        "foregroundImage": "./assets/images/app_logo_final.png",
        "monochromeImage": "./assets/images/app_logo_final.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_logo_final.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0E1510",
          "dark": {
            "backgroundColor": "#0E1510"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4fde061b-0c98-4f8b-b3e2-97623c5cbd4c"
      }
    },
    "owner": "mivah-ram"
  }
}